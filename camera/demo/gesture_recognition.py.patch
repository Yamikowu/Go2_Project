+        # 改用計算距離與向量的方式，而不是單純看 Y 坐標
+        # 這樣手轉 90 度或反過來也能辨識
+
+        def calc_distance(p1, p2):
+            return math.hypot(p1.x - p2.x, p1.y - p2.y)
+
+        # --- 判斷大拇指 ---
+        # 比較 大拇指尖端(4)到小拇指根部(17)的距離 與 大拇指關節(3)到小拇指根部的距離
+        # 如果尖端離得比較遠，代表大拇指是張開的
+        if calc_distance(landmarks[4], landmarks[17]) > calc_distance(landmarks[3], landmarks[17]):
             fingers.append(1)
         else:
             fingers.append(0)
 
-        # --- 判斷其他四根手指 (看 Y 軸) ---
